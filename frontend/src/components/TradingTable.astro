---
interface Signal {
  ticker: string;
  universe: string;
  action: string;
  entry: number | null;
  stop: number | null;
  stop_pct: number | null;
  t1: number | null;
  t2: number | null;
  t3: number | null;
  rr1: number | null;
  rr2: number | null;
  rr3: number | null;
}
interface Props {
  signals: Signal[];
}
const { signals } = Astro.props;
const fmt = (v: number | null, digits = 2) => (v === null || v === undefined ? "—" : v.toFixed(digits));
---
<div class="bg-[#0f172a] border border-[#1e293b] rounded-xl overflow-hidden shadow-xl">
  <div class="px-6 py-4 border-b border-[#1e293b]">
    <h2 class="text-sm font-semibold text-gray-300 uppercase tracking-wider m-0 p-0 bg-transparent border-0">
      Piano d'Azione Operativo
    </h2>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full min-w-[900px]" style="margin:0; border:0;">
      <thead>
        <tr class="border-b border-[#1e293b] bg-[#111827]">
          <th class="px-6 py-3 text-left text-xs font-medium text-blue-400 uppercase tracking-wider border-0">Ticker</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider border-0">Universo</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-blue-400 uppercase tracking-wider border-0">Esito</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-blue-400 uppercase tracking-wider border-0">Trigger Ingresso</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-rose-400 uppercase tracking-wider border-0">Stop-Loss</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-emerald-400 uppercase tracking-wider border-0">T1 (R/R)</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-emerald-400 uppercase tracking-wider border-0">T2 (R/R)</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-emerald-400 uppercase tracking-wider border-0">T3 (R/R)</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-[#1e293b]">
        {signals.map((trade, index) => (
          <tr class={`${index % 2 === 0 ? "bg-transparent" : "bg-[#111827]/40"} ${trade.action !== "BUY" ? "opacity-50" : ""}`}>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-bold font-mono border-0">
              <a href={`#${trade.ticker}`} class="hover:text-blue-400">{trade.ticker}</a>
              {trade.universe === "unicorn" && <span class="ml-1 text-amber-400" title="Unicorno">★</span>}
            </td>
            <td class="px-4 py-4 whitespace-nowrap text-xs text-gray-500 border-0">
              {trade.universe === "unicorn" ? "unicorno" : "mega-cap"}
            </td>
            <td class="px-6 py-4 whitespace-nowrap border-0">
              <span class={`px-2.5 py-0.5 rounded text-xs font-semibold ${trade.action === "BUY" ? "bg-emerald-500/10 text-emerald-400" : "bg-rose-500/10 text-rose-400"}`}>
                {trade.action}
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-mono border-0">{fmt(trade.entry)}</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-rose-400 font-semibold border-0">
              {trade.stop === null ? "—" : `${fmt(trade.stop)} (-${(trade.stop_pct! * 100).toFixed(1)}%)`}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-emerald-400 border-0">
              {trade.t1 === null ? "—" : `${fmt(trade.t1)} (${trade.rr1}:1)`}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-emerald-400/80 border-0">
              {trade.t2 === null ? "—" : `${fmt(trade.t2)} (${trade.rr2}:1)`}
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-mono text-emerald-400/60 border-0">
              {trade.t3 === null ? "—" : `${fmt(trade.t3)} (${trade.rr3}:1)`}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
