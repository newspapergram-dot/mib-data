---
import Layout from '../../layouts/Layout.astro';
import manifest from '../../../public/data/manifest.json';
---
<Layout title="MIB-DATA // Archivio storico">
  <header class="border-b border-[#1e293b] bg-[#0f172a]/80 backdrop-blur px-6 py-4 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
      <h1 class="text-xl font-bold tracking-wider text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400">
        MIB-DATA // ARCHIVIO STORICO
      </h1>
      <a href="/" class="text-xs text-blue-300 hover:text-blue-200">← Torna all'ultima notte</a>
    </div>
  </header>
  <main class="max-w-3xl mx-auto px-6 py-8">
    {manifest.length === 0 ? (
      <p class="text-gray-500 text-sm">Nessuna nottata ancora archiviata.</p>
    ) : (
      <div class="bg-[#0f172a] border border-[#1e293b] rounded-xl overflow-hidden divide-y divide-[#1e293b]">
        {manifest.map((run) => (
          <a href={`/archive/${run.date}/`} class="flex items-center justify-between px-6 py-4 hover:bg-[#111827]/60 transition no-underline text-inherit">
            <span class="font-mono text-sm">{run.date}</span>
            <span class="flex items-center gap-4 text-xs">
              <span class="text-emerald-400">{run.buy} BUY</span>
              <span class="text-rose-400">{run.skip} SKIP</span>
              <span class="text-gray-500">{run.total} valutati</span>
            </span>
          </a>
        ))}
      </div>
    )}
  </main>
</Layout>
